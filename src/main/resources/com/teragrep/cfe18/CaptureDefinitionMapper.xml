<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.teragrep.cfe18.CaptureDefinitionMapper">

    <!-- GET (id int, tx_id int) -->
    <select id="get" resultMap="captureDefinition" statementType="CALLABLE">
        {CALL cfe_18.select_capture_definition(#{param1},#{param2})}
    </select>

    <!-- GET All ( metadatakey varchar(255), tx_id INT) -->
    <select id="getAll" resultMap="captureDefinition" statementType="CALLABLE">
        {CALL cfe_18.select_all_capture_definitions(#{param1},#{param2})}
    </select>

    <resultMap id="captureDefinition" type="com.teragrep.cfe18.handlers.entities.CaptureDefinition">
        <result property="id" column="id"/>
        <result property="tag" column="tag"/>
        <result property="sourcetype" column="sourcetype"/>
        <result property="application" column="application"/>
        <result property="captureIndex" column="capture_index"/>
    </resultMap>


</mapper>
